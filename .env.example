# LiteLLM — local proxy: see litellm-proxy/README.md (run on port 4000)
LITELLM_API_KEY=must-match-LITELLM_MASTER_KEY-in-litellm-proxy-.env
LITELLM_BASE_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql+asyncpg://pipelinelab:pipelinelab@postgres:5432/pipelinelab

# Optional: Direct API keys (if not using LiteLLM proxy)
OPENAI_API_KEY=
COHERE_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Feature Flags
NEXT_PUBLIC_ENABLE_SHADERS=false
